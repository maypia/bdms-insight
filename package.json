{
  "name": "bdms-insight-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Hospital Expense & Accounts Payable Monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "turbo run db:generate --filter=@hospital-ap/database",
    "db:migrate": "turbo run db:migrate --filter=@hospital-ap/database"
  },
  "devDependencies": {
    "turbo": "^1.12.4",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
